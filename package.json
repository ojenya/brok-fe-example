{
  "name": "brok-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "public/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:serve": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_VITE_DEV_URL=http://localhost:5173 pnpm electron:start\"",
    "electron:build": "pnpm build && electron-builder",
    "gen:sources": "openapi-generator-cli generate -i ../brok-be-example/brok-core/openapi.yaml --generator-name typescript-fetch --output src/generated-sources/core"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "kill-port": "^2.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.3",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.example.brok-demo",
    "productName": "BrOk Demo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "public/**"
    ],
    "extraFiles": [
      {
        "from": "jars",
        "to": "resources/jars",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": ["pkg"]
    },
    "pkg": {
      "scripts": "public/pkg-scripts",
      "installLocation": "/Applications"
    }
  }
}
